<Application x:Class="GlassLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Тема по умолчанию загружается из кода (App.xaml.cs) -->
                <ResourceDictionary Source="UI/Styles/Theme.Dark.xaml"/>
                <ResourceDictionary Source="UI/Styles/Glass.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>