<Window x:Class="GlassLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GlassLauncher.ViewModels"
        Title="GlassLauncher" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Grid>
        <!-- Размытая фоновая подложка (glassmorphism) -->
        <Border Style="{StaticResource BlurLayer}">
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource AccentA}" Offset="0"/>
                        <GradientStop Color="{DynamicResource AccentB}" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Border>

        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ: профиль и темы -->
            <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <!-- Аватар скина Ely.by -->
                    <Border Width="96" Height="96" CornerRadius="48" Background="#33FFFFFF" Margin="0,8,0,12">
                        <Image Source="{Binding SkinUrl, Converter={StaticResource UrlToImg}}"
                               Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="{Binding Username}" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"/>

                    <Button Content="Войти через Ely.by" Style="{StaticResource GlassButton}"
                            Margin="0,16,0,0" Command="{Binding LoginCommand}"/>

                    <TextBlock Text="Тема оформления" Margin="0,28,0,6"
                               Foreground="{DynamicResource TextBrush}" Opacity="0.7"/>
                    <ComboBox ItemsSource="{Binding Themes}"
                              SelectionChanged="ThemeCombo_SelectionChanged"
                              SelectedItem="{Binding DataContext.SelectedThemeProxy, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Border>

            <!-- ПРАВАЯ ОБЛАСТЬ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Вкладки -->
                <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0">
                    <!-- ГЛАВНАЯ -->
                    <TabItem Header="Главная">
                        <Border Style="{StaticResource GlassPanel}" Padding="32" Margin="0,8,0,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="GlassLauncher" FontSize="40" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Выберите версию и нажмите Играть"
                                           Opacity="0.7" Margin="0,0,0,20"
                                           Foreground="{DynamicResource TextBrush}"/>

                                <TextBlock Text="Версия Minecraft" Margin="0,0,0,4"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <ComboBox ItemsSource="{Binding Versions}"
                                          SelectedItem="{Binding SelectedVersion}"
                                          Width="320" HorizontalAlignment="Left" Margin="0,0,0,24"/>

                                <Button Content="▶  ИГРАТЬ" Style="{StaticResource PlayButton}"
                                        Width="320" HorizontalAlignment="Left"
                                        Command="{Binding PlayCommand}"/>
                            </StackPanel>
                        </Border>
                    </TabItem>

                    <!-- МОДЫ -->
                    <TabItem Header="Моды">
                        <Border Style="{StaticResource GlassPanel}" Padding="20" Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="Найти"
                                            Style="{StaticResource GlassButton}" Margin="8,0,0,0"
                                            Command="{Binding SearchModsCommand}"
                                            CommandParameter="{Binding Text, ElementName=SearchBox}"/>
                                    <TextBox x:Name="SearchBox" FontSize="15" Padding="8"
                                             Background="#22FFFFFF" Foreground="{DynamicResource TextBrush}"
                                             BorderThickness="0"/>
                                </DockPanel>

                                <!-- Карточки модов -->
                                <ScrollViewer Grid.Row="1">
                                    <ItemsControl ItemsSource="{Binding Mods}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource GlassPanel}" Padding="12" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="56"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Image Grid.Column="0" Width="48" Height="48"
                                                               Source="{Binding IconUrl, Converter={StaticResource UrlToImg}}"/>
                                                        <StackPanel Grid.Column="1" Margin="12,0">
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                                       Foreground="{DynamicResource TextBrush}"/>
                                                            <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis"
                                                                       Opacity="0.7" Foreground="{DynamicResource TextBrush}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Content="Скачать"
                                                                Style="{StaticResource GlassButton}"
                                                                Command="{Binding DataContext.DownloadModCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>

                <!-- НИЖНЯЯ ПАНЕЛЬ: статус + прогресс -->
                <Border Grid.Row="1" Style="{StaticResource GlassPanel}" Padding="16" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource TextBrush}"/>
                        <ProgressBar Style="{StaticResource GlassProgress}"
                                     Value="{Binding Progress}" Maximum="100" Margin="0,8,0,0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>