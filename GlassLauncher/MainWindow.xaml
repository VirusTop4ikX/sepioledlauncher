<Window x:Class="GlassLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GlassLauncher" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="Segoe UI">

    <Grid x:Name="RootGrid" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->
        <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Padding="18" Margin="0,0,16,0">
            <StackPanel>
                <Border Width="84" Height="84" CornerRadius="12" Background="{DynamicResource GlassBrush}"
                        Margin="0,4,0,10" HorizontalAlignment="Center">
                    <Image Source="{Binding SkinUrl, Converter={StaticResource UrlToImg}}" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="{Binding Username}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>

                <Separator Margin="0,16" Background="{DynamicResource BorderBrush2}"/>

                <!-- Переключатель режима входа -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="3" Margin="0,0,0,12"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush2}">
                    <UniformGrid Columns="2">
                        <RadioButton x:Name="ModeEly" Style="{StaticResource SegmentRadio}" Content="Ely.by" IsChecked="True"/>
                        <RadioButton x:Name="ModeOffline" Style="{StaticResource SegmentRadio}" Content="По нику"/>
                    </UniformGrid>
                </Border>

                <!-- Вход Ely.by -->
                <StackPanel Visibility="{Binding IsChecked, ElementName=ModeEly, Converter={StaticResource BoolToVis}}">
                    <Button Content="Войти через Ely.by" Style="{StaticResource AccentButton}"
                            Command="{Binding LoginCommand}"/>
                </StackPanel>

                <!-- Оффлайн-вход + скин -->
                <StackPanel Visibility="{Binding IsChecked, ElementName=ModeOffline, Converter={StaticResource BoolToVis}}">
                    <TextBox Text="{Binding OfflineUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <Button Content="Войти" Style="{StaticResource AccentButton}" Command="{Binding LoginOfflineCommand}"/>

                    <TextBlock Text="Скин" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,14,0,6"/>
                    <Button Content="Выбрать PNG-файл" Style="{StaticResource GlassButton}"
                            Margin="0,0,0,6" Command="{Binding PickSkinFileCommand}"/>
                    <TextBox x:Name="SkinUrlBox" Margin="0,0,0,6"/>
                    <Button Content="Скин по ссылке" Style="{StaticResource GlassButton}"
                            Margin="0,0,0,6"
                            Command="{Binding SetSkinUrlCommand}"
                            CommandParameter="{Binding Text, ElementName=SkinUrlBox}"/>
                    <Button Content="Включить скин в игре" Style="{StaticResource GlassButton}"
                            Command="{Binding InstallSkinModCommand}"
                            ToolTip="Ставит CustomSkinLoader — нужен для показа скина в offline-режиме"/>
                </StackPanel>

                <Separator Margin="0,16" Background="{DynamicResource BorderBrush2}"/>

                <TextBlock Text="Тема" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                <ComboBox x:Name="ThemeCombo" ItemsSource="{Binding Themes}"
                          SelectionChanged="ThemeCombo_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- ПРАВАЯ ОБЛАСТЬ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0">
                <!-- ГЛАВНАЯ -->
                <TabItem Header="Главная">
                    <Border Style="{StaticResource GlassPanel}" Padding="36" Margin="0,12,0,0">
                        <StackPanel VerticalAlignment="Center" MaxWidth="400" HorizontalAlignment="Left">
                            <TextBlock Text="GlassLauncher" FontSize="30" FontWeight="Bold"/>
                            <TextBlock Text="Выберите загрузчик, версию и запустите игру"
                                       Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,22"/>

                            <TextBlock Text="Загрузчик" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Loaders}" SelectedItem="{Binding SelectedLoader}" Margin="0,0,0,14"/>

                            <TextBlock Text="Версия" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}"/>

                            <CheckBox Content="Показывать снапшоты" Margin="2,10,0,22"
                                      IsChecked="{Binding IncludeSnapshots}"/>

                            <Button Content="ИГРАТЬ" Style="{StaticResource PlayButton}" Command="{Binding PlayCommand}"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- КОНТЕНТ (моды + ресурспаки) -->
                <TabItem Header="Контент">
                    <Border Style="{StaticResource GlassPanel}" Padding="18" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                <ComboBox DockPanel.Dock="Left" Width="130" Margin="0,0,8,0"
                                          ItemsSource="{Binding ContentKinds}" SelectedItem="{Binding SelectedContentKind}"/>
                                <Button DockPanel.Dock="Right" Content="Найти" Style="{StaticResource AccentButton}"
                                        Margin="8,0,0,0" Command="{Binding SearchModsCommand}"
                                        CommandParameter="{Binding Text, ElementName=SearchBox}"/>
                                <TextBox x:Name="SearchBox"/>
                            </DockPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Mods}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource GlassBrush}" CornerRadius="10"
                                                    Padding="12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                            Background="{DynamicResource SurfaceBrush}">
                                                        <Image Source="{Binding IconUrl, Converter={StaticResource UrlToImg}}"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Content="Скачать" VerticalAlignment="Center"
                                                            Style="{StaticResource GlassButton}"
                                                            Command="{Binding DataContext.DownloadModCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- НАСТРОЙКИ ЗАПУСКА -->
                <TabItem Header="Настройки">
                    <Border Style="{StaticResource GlassPanel}" Padding="28" Margin="0,12,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="460" HorizontalAlignment="Left">
                                <TextBlock Text="Настройки запуска" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>

                                <TextBlock Text="Оперативная память (МБ)" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding RamMb}" Margin="0,0,0,14"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ширина окна" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding ScreenWidth}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Высота окна" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding ScreenHeight}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Доп. аргументы JVM" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding JvmArgs}" Margin="0,0,0,14"/>

                                <TextBlock Text="Путь к Java" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <DockPanel Margin="0,0,0,14">
                                    <Button DockPanel.Dock="Right" Content="Обзор" Style="{StaticResource GlassButton}"
                                            Margin="8,0,0,0" Command="{Binding PickJavaPathCommand}"/>
                                    <TextBox Text="{Binding JavaPath}"/>
                                </DockPanel>

                                <TextBlock Text="Папка игры (.minecraft)" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                <DockPanel Margin="0,0,0,14">
                                    <Button DockPanel.Dock="Right" Content="Обзор" Style="{StaticResource GlassButton}"
                                            Margin="8,0,0,0" Command="{Binding PickGameDirCommand}"/>
                                    <TextBox Text="{Binding GameDirectory}"/>
                                </DockPanel>

                                <CheckBox Content="Сворачивать лаунчер при запуске игры" Margin="2,0,0,20"
                                          IsChecked="{Binding MinimizeOnLaunch}"/>

                                <Button Content="Сохранить настройки" Style="{StaticResource AccentButton}"
                                        HorizontalAlignment="Left" Command="{Binding SaveSettingsCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- СТАТУС-БАР -->
            <Border Grid.Row="1" Style="{StaticResource GlassPanel}" Padding="14" Margin="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding Status}"/>
                    <ProgressBar Style="{StaticResource GlassProgress}" Value="{Binding Progress}" Maximum="100"
                                 Margin="0,8,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>