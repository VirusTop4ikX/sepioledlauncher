<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Светлая: мягкий светлый фон + мятно-зелёный акцент -->
    <Color x:Key="BgColor">#F4F6F8</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="GlassColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#1FAE6E</Color>
    <Color x:Key="AccentDimColor">#178A57</Color>
    <Color x:Key="TextColor">#1A1F24</Color>
    <Color x:Key="MutedColor">#6B7480</Color>
    <Color x:Key="BorderColor">#E2E6EA</Color>

    <SolidColorBrush x:Key="BgBrush"        Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"   Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="GlassBrush"     Color="{StaticResource GlassColor}" Opacity="0.7"/>
    <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="TextBrush"      Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="MutedBrush"     Color="{StaticResource MutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush2"   Color="{StaticResource BorderColor}"/>
</ResourceDictionary>