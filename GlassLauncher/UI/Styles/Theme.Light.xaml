<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Светлая: белый с голубым -->
    <Color x:Key="BgColor">#EAF2FF</Color>
    <Color x:Key="GlassColor">#FFFFFF</Color>
    <Color x:Key="AccentA">#2196F3</Color>
    <Color x:Key="AccentB">#00BCD4</Color>
    <Color x:Key="TextColor">#10243A</Color>

    <SolidColorBrush x:Key="BgBrush"   Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentA}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentB}" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassColor}" Opacity="0.55"/>
</ResourceDictionary>