<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Тёмная: матовый тёмный фон + мятно-зелёный акцент -->
    <Color x:Key="BgColor">#14171C</Color>
    <Color x:Key="SurfaceColor">#1C2128</Color>
    <Color x:Key="GlassColor">#232A33</Color>
    <Color x:Key="AccentColor">#3DDC97</Color>
    <Color x:Key="AccentDimColor">#2BB37A</Color>
    <Color x:Key="TextColor">#E8ECEF</Color>
    <Color x:Key="MutedColor">#8A93A0</Color>
    <Color x:Key="BorderColor">#2C333D</Color>

    <SolidColorBrush x:Key="BgBrush"        Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"   Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="GlassBrush"     Color="{StaticResource GlassColor}" Opacity="0.65"/>
    <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="TextBrush"      Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="MutedBrush"     Color="{StaticResource MutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush2"   Color="{StaticResource BorderColor}"/>
</ResourceDictionary>