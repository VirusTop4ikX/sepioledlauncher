<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Тёмная: тёмно-синий с фиолетовым -->
    <Color x:Key="BgColor">#0E0B1F</Color>
    <Color x:Key="GlassColor">#332A4A</Color>
    <Color x:Key="AccentA">#7C4DFF</Color>
    <Color x:Key="AccentB">#3D5AFE</Color>
    <Color x:Key="TextColor">#F0EEFF</Color>

    <SolidColorBrush x:Key="BgBrush"    Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="TextBrush"  Color="{StaticResource TextColor}" />
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentA}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentB}" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassColor}" Opacity="0.45"/>
</ResourceDictionary>