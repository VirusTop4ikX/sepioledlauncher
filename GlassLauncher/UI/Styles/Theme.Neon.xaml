<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Неоновая: чёрный с ярко-розовым/зелёным -->
    <Color x:Key="BgColor">#050008</Color>
    <Color x:Key="GlassColor">#1A0A24</Color>
    <Color x:Key="AccentA">#FF1FA2</Color>
    <Color x:Key="AccentB">#39FF14</Color>
    <Color x:Key="TextColor">#F2FFF8</Color>

    <SolidColorBrush x:Key="BgBrush"   Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentA}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentB}" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassColor}" Opacity="0.5"/>
</ResourceDictionary>