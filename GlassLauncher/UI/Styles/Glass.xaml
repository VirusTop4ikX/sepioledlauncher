<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:GlassLauncher.UI">

    <ui:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <ui:UrlToImageConverter x:Key="UrlToImg"/>

    <!-- Стеклянная панель: полупрозрачный фон + размытие подложки -->
    <Style x:Key="GlassPanel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource GlassBrush}"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.35" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Слой размытия фона (BlurEffect) -->
    <Style x:Key="BlurLayer" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value><BlurEffect Radius="40"/></Setter.Value>
        </Setter>
    </Style>

    <!-- Градиентная кнопка с анимацией наведения/нажатия/появления -->
    <Style x:Key="GlassButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="14" Padding="18,10"
                            RenderTransformOrigin="0.5,0.5">
                        <!-- ScaleTransform объявлен ДО триггеров, имя 'st' видно из них -->
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="st" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Появление -->
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="b"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1" Duration="0:0:0.35"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Наведение: увеличение -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="st"
                                        Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.15"/>
                                    <DoubleAnimation Storyboard.TargetName="st"
                                        Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- Уход курсора: возврат -->
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="st"
                                        Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15"/>
                                    <DoubleAnimation Storyboard.TargetName="st"
                                        Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Нажатие: лёгкое сжатие -->
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="st"
                                        Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.08"/>
                                    <DoubleAnimation Storyboard.TargetName="st"
                                        Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.08"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- Отпускание: возврат к hover-размеру -->
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="st"
                                        Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="st"
                                        Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Большая кнопка "Играть" -->
    <Style x:Key="PlayButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Height" Value="64"/>
    </Style>

    <!-- Анимированный прогресс-бар -->
    <Style x:Key="GlassProgress" TargetType="ProgressBar">
        <Setter Property="Height" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Background" Value="#22FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
</ResourceDictionary>