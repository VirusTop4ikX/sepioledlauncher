<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:GlassLauncher.UI">

    <ui:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <ui:UrlToImageConverter x:Key="UrlToImg"/>

    <!-- Стеклянная панель: полупрозрачный фон + размытие подложки -->
    <Style x:Key="GlassPanel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource GlassBrush}"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.35" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Слой размытия фона (BlurEffect) -->
    <Style x:Key="BlurLayer" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value><BlurEffect Radius="40"/></Setter.Value>
        </Setter>
    </Style>

    <!-- Градиентная кнопка с анимацией наведения/нажатия/появления -->
    <Style x:Key="GlassButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="14" Padding="18,10">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="st" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Появление -->
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="b"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1" Duration="0:0:0.35"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- Наведение -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="st"
                                            Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="st"
                                            Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="st"
                                            Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="st"
                                            Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Нажатие -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="st" Property="ScaleX" Value="0.96"/>
                            <Setter TargetName="st" Property="ScaleY" Value="0.96"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Большая кнопка "Играть" -->
    <Style x:Key="PlayButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Height" Value="64"/>
    </Style>

    <!-- Анимированный прогресс-бар -->
    <Style x:Key="GlassProgress" TargetType="ProgressBar">
        <Setter Property="Height" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Background" Value="#22FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
</ResourceDictionary>